{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "strict": true,

    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    
    "paths": {
      "@pages/*": ["pages/*"],
      "@components/*": ["pages/components/*"],
      "@core/*": ["core/*"],
      "@utils/*": ["utils/*"],
      "@fixtures/*": ["fixtures/*"]
    },

    "types": ["node", "@playwright/test"],
  },

  "include": [
   // "src/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts"
  ]
}